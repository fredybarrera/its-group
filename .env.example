# URL pública del sitio (canonical, Open Graph y sitemap)
NUXT_PUBLIC_SITE_URL=https://itsgroup.dev

# Widget de agendamiento Calendly (URL pública de tu evento)
NUXT_PUBLIC_CALENDLY_URL=https://calendly.com/itsgroup/30min

# --- Formulario de contacto (Resend) — solo servidor, NUNCA versionar valores reales ---
# Clave de API de Resend (https://resend.com/api-keys)
NUXT_RESEND_API_KEY=
# Correo destino que recibe las solicitudes del formulario
NUXT_CONTACT_TO_EMAIL=contacto@itsgroup.dev
# Remitente: debe pertenecer a un dominio verificado en Resend (itsgroup.dev)
NUXT_CONTACT_FROM_EMAIL=IT Solutions Group <contacto@itsgroup.dev>
